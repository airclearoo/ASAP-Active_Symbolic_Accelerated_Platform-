# =============================================================================
# ASAP - Active Symbolic Accelerated Platform
# 测试工作目录配置文件
# =============================================================================
# 说明：这是一个测试用的 INPUT 文件示例
# 使用方法：
#   1. 复制此文件到工作目录
#   2. 修改路径为你实际的数据文件
#   3. 运行：asap -r INPUT
# =============================================================================

# -----------------------------------------------------------------------------
# 【必填】数据文件路径
# -----------------------------------------------------------------------------

# 训练数据文件（CSV 格式）
TRAIN_DATA = ../../scripts/sisso/nested_CV/data.csv

# 候选材料数据库（ASE .db 格式）
CANDIDATE_DB = ../../data/benchmark/design.db

# MACE 模型文件（.model 格式）
MACE_MODEL = ../../mace_model/2023-12-03-mace-128-L1_epoch-199.model

# 输出目录（会自动创建）
OUTPUT_DIR = test_output3

# -----------------------------------------------------------------------------
# 【可选】SISSO 参数配置
# -----------------------------------------------------------------------------

PROP_LABEL = g_pbx
PROP_UNIT = eV/atom
ALLOWED_OPS = add,sub,mult,div,inv,sq,sqrt,cbrt,log,abs
N_DIM = 2
MAX_RUNG = 2
N_SIS_SELECT = 50
N_RESIDUAL = 5
L_BOUND = 1e-5
U_BOUND = 1e+5

# -----------------------------------------------------------------------------
# 【可选】主动学习参数
# -----------------------------------------------------------------------------

# 快速测试：减少迭代次数
AL_N_ITERATIONS = 5
AL_BATCH_SIZE = 3
AL_UCB_KAPPA = 0.1
TEST_SIZE = 0.2
RANDOM_STATE = 42

# -----------------------------------------------------------------------------
# 【可选】MACE 计算配置
# -----------------------------------------------------------------------------

MACE_DEVICE = cpu
MACE_RELAX = False
MACE_RELAX_FMAX = 0.05
MACE_RELAX_STEPS = 50

# -----------------------------------------------------------------------------
# 【可选】性能调优参数
# -----------------------------------------------------------------------------

RF_N_ESTIMATORS = 50
SUPPRESS_WARNINGS = True
MATPLOTLIB_BACKEND = Agg

# -----------------------------------------------------------------------------
# 【可选】调试选项
# -----------------------------------------------------------------------------

DEBUG_MODE = True
QUICK_TEST = True
QUICK_TEST_ITERATIONS = 5
