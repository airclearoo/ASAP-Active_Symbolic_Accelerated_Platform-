#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
ASAP - Active Symbolic Accelerated Platform
命令行工具

使用方法:
    asap -r              运行工作流
    asap -c              检查环境
    asap -i              显示信息
    asap -h              显示帮助
    asap --run           运行工作流（同 -r）
    asap --check         检查环境（同 -c）
    asap --info          显示信息（同 -i）
    asap --help          显示帮助（同 -h）
    asap -r /path/INPUT  使用指定配置文件运行
"""

import sys
import os
from pathlib import Path

# 获取脚本所在目录（使用绝对路径）
SCRIPT_DIR = Path(__file__).parent.resolve()

# 尝试从环境变量获取项目目录，或使用默认路径
ASAP_PROJECT = os.environ.get('ASAP_PROJECT', '/home/user/1-yjy/sisso_mace_al_workflow')
PROJECT_DIR = Path(ASAP_PROJECT)
PYTHON_DIR = PROJECT_DIR / 'scripts' / 'python'
CONFIG_DIR = PROJECT_DIR / 'scripts' / 'config'

# 添加 Python 目录到路径
sys.path.insert(0, str(PYTHON_DIR))
sys.path.insert(0, str(CONFIG_DIR))

import argparse


def print_banner():
    """打印横幅"""
    print("=" * 70)
    print("  ASAP - Active Symbolic Accelerated Platform")
    print("  主动符号加速平台")
    print("=" * 70)


def print_info():
    """显示信息"""
    print_banner()
    print()
    print("版本：1.0.0")
    print("作者：NewtonYe")
    print("论文：待定")
    print("待定")
    print()
    print("使用方法:")
    print("  asap -r              运行工作流（主动学习）")
    print("  asap -p              SISSO 模型预测")
    print("  asap -c              检查环境")
    print("  asap -i              显示信息")
    print("  asap -h              显示帮助")
    print()
    print("高级用法:")
    print("  asap -r /path/INPUT     使用指定配置文件运行工作流")
    print("  asap -p /path/CONFIG    使用指定配置文件进行预测")
    print()


def check_environment():
    """检查环境"""
    print_banner()
    print()
    print("检查环境和依赖...")
    print()
    
    all_ok = True
    
    # 检查 Python 版本
    print(f"[1/6] Python 版本：{sys.version.split()[0]}")
    if sys.version_info >= (3, 9):
        print("  ✓ Python 版本符合要求")
    else:
        print("  ⚠ 警告：Python 版本过低，建议 3.9+")
    print()
    
    # 检查 SISSO
    print("[2/6] 检查 SISSO...")
    try:
        from sissopp.sklearn import SISSORegressor
        print("  ✓ SISSO 已安装")
    except ImportError as e:
        print(f"  ✗ SISSO 未安装：{e}")
        all_ok = False
    print()
    
    # 检查 MACE
    print("[3/6] 检查 MACE...")
    try:
        import mace
        print("  ✓ MACE 已安装")
    except ImportError as e:
        print(f"  ✗ MACE 未安装：{e}")
        all_ok = False
    print()
    
    # 检查 ASE
    print("[4/6] 检查 ASE...")
    try:
        from ase.db import connect
        print("  ✓ ASE 已安装")
    except ImportError as e:
        print(f"  ✗ ASE 未安装：{e}")
        all_ok = False
    print()
    
    # 检查科学计算库
    print("[5/6] 检查科学计算库...")
    required = ['pandas', 'numpy', 'sklearn', 'matplotlib']
    for pkg in required:
        try:
            __import__(pkg)
            print(f"  ✓ {pkg} 已安装")
        except ImportError:
            print(f"  ✗ {pkg} 未安装")
            all_ok = False
    print()
    
    # 检查配置文件
    print("[6/6] 检查配置文件...")
    input_path = CONFIG_DIR / 'INPUT'
    if input_path.exists():
        print(f"  ✓ INPUT 配置文件存在")
    else:
        print(f"  ⚠ INPUT 配置文件不存在（可运行时指定）")
    print()
    
    print("=" * 70)
    if all_ok:
        print("✓ 所有检查通过！环境配置正确。")
    else:
        print("⚠ 部分检查未通过，请查看上方错误信息。")
    print("=" * 70)
    
    return all_ok


def run_workflow(config_path=None):
    """运行工作流"""
    print_banner()
    print()
    
    # 确定配置目录
    if config_path:
        config_path = Path(config_path)
        # 如果是相对路径，转换为当前工作目录的绝对路径
        if not config_path.is_absolute():
            config_path = Path.cwd() / config_path
        config_dir = config_path.parent
        print(f"使用配置文件：{config_path}")
    else:
        config_dir = CONFIG_DIR
        print(f"使用默认配置：{CONFIG_DIR}/INPUT")
    print()
    
    # 直接解析配置文件
    input_file = config_path.name if config_path else 'INPUT'
    input_path = config_dir / input_file
    
    if not input_path.exists():
        print(f"✗ 错误：配置文件不存在：{input_path}")
        return False
    
    try:
        from config_loader import parse_input_file, get_bool, get_int, get_float, get_list
        config = parse_input_file(input_path)
    except FileNotFoundError as e:
        print(f"✗ 错误：配置文件不存在")
        print(f"  请创建配置文件或使用 -r 指定配置文件路径")
        return False
    except Exception as e:
        print(f"✗ 配置解析错误：{e}")
        return False
    
    # 显示配置
    print("配置参数:")
    print(f"  训练数据：{config.get('TRAIN_DATA', 'N/A')}")
    print(f"  候选数据库：{config.get('CANDIDATE_DB', 'N/A')}")
    print(f"  MACE 模型：{config.get('MACE_MODEL', 'N/A')}")
    print(f"  输出目录：{config.get('OUTPUT_DIR', 'N/A')}")
    print(f"  迭代次数：{config.get('AL_N_ITERATIONS', 'N/A')}")
    print(f"  批次大小：{config.get('AL_BATCH_SIZE', 'N/A')}")
    print(f"  MACE 弛豫：{config.get('MACE_RELAX', 'N/A')}")
    print()
    
    # 转换相对路径为绝对路径（相对于 INPUT 文件所在目录）
    for key in ['TRAIN_DATA', 'CANDIDATE_DB', 'MACE_MODEL', 'OUTPUT_DIR']:
        path = config.get(key)
        if path and not os.path.isabs(path):
            config[key] = str((config_dir / path).resolve())
    
    # 验证必要文件
    print("验证数据文件...")
    required_files = ['TRAIN_DATA', 'CANDIDATE_DB', 'MACE_MODEL']
    missing = []
    for key in required_files:
        path = config.get(key)
        if path and not os.path.exists(path):
            missing.append(f"{key}: {path}")
    
    if missing:
        print("✗ 以下文件缺失:")
        for m in missing:
            print(f"    {m}")
        print()
        print("请检查 INPUT 配置文件中的路径设置。")
        return False
    
    print("✓ 所有数据文件存在")
    print()
    
    # 导入并运行主工作流
    print("=" * 70)
    print("开始运行工作流...")
    print("=" * 70)
    print()
    
    try:
        import workflow_active_learning_mace_fixed as workflow
        
        # 覆盖配置
        workflow.DATA_FILE = config.get('TRAIN_DATA', workflow.DATA_FILE)
        workflow.CANDIDATE_DB = config.get('CANDIDATE_DB', workflow.CANDIDATE_DB)
        workflow.OUTPUT_DIR = config.get('OUTPUT_DIR', workflow.OUTPUT_DIR)
        
        # SISSO 参数
        workflow.SISSO_PARAMS['prop_label'] = config.get('PROP_LABEL', workflow.SISSO_PARAMS['prop_label'])
        workflow.SISSO_PARAMS['prop_unit'] = config.get('PROP_UNIT', workflow.SISSO_PARAMS['prop_unit'])
        workflow.SISSO_PARAMS['allowed_ops'] = get_list(config, 'ALLOWED_OPS', workflow.SISSO_PARAMS['allowed_ops'])
        workflow.SISSO_PARAMS['n_dim'] = get_int(config, 'N_DIM', workflow.SISSO_PARAMS['n_dim'])
        workflow.SISSO_PARAMS['max_rung'] = get_int(config, 'MAX_RUNG', workflow.SISSO_PARAMS['max_rung'])
        workflow.SISSO_PARAMS['n_sis_select'] = get_int(config, 'N_SIS_SELECT', workflow.SISSO_PARAMS['n_sis_select'])
        workflow.SISSO_PARAMS['n_residual'] = get_int(config, 'N_RESIDUAL', workflow.SISSO_PARAMS['n_residual'])
        workflow.SISSO_PARAMS['l_bound'] = get_float(config, 'L_BOUND', workflow.SISSO_PARAMS['l_bound'])
        workflow.SISSO_PARAMS['u_bound'] = get_float(config, 'U_BOUND', workflow.SISSO_PARAMS['u_bound'])
        
        # 主动学习参数
        workflow.AL_N_ITERATIONS = get_int(config, 'AL_N_ITERATIONS', workflow.AL_N_ITERATIONS)
        workflow.AL_BATCH_SIZE = get_int(config, 'AL_BATCH_SIZE', workflow.AL_BATCH_SIZE)
        workflow.AL_UCB_KAPPA = get_float(config, 'AL_UCB_KAPPA', workflow.AL_UCB_KAPPA)
        workflow.TEST_SIZE = get_float(config, 'TEST_SIZE', workflow.TEST_SIZE)
        workflow.RANDOM_STATE = get_int(config, 'RANDOM_STATE', workflow.RANDOM_STATE)
        
        # MACE 参数
        workflow.MACE_MODEL = config.get('MACE_MODEL', workflow.MACE_MODEL)
        workflow.MACE_DEVICE = config.get('MACE_DEVICE', workflow.MACE_DEVICE)
        workflow.MACE_RELAX = get_bool(config, 'MACE_RELAX', workflow.MACE_RELAX)
        workflow.MACE_RELAX_FMAX = get_float(config, 'MACE_RELAX_FMAX', workflow.MACE_RELAX_FMAX)
        workflow.MACE_RELAX_STEPS = get_int(config, 'MACE_RELAX_STEPS', workflow.MACE_RELAX_STEPS)
        
        # 运行
        workflow.main()
        return True
        
    except Exception as e:
        print()
        print("=" * 70)
        print(f"✗ 工作流运行失败：{e}")
        print("=" * 70)
        import traceback
        traceback.print_exc()
        return False


def run_prediction_cli(config_path=None):
    """运行预测（CLI 包装）"""
    from pathlib import Path
    import importlib.util
    import os
    
    # 如果是相对路径，转换为绝对路径
    if config_path:
        config_path = str(Path(config_path).resolve())
    
    # 加载预测脚本
    predict_script = PYTHON_DIR / 'sisso_predict.py'
    if not predict_script.exists():
        print(f"✗ 预测脚本不存在：{predict_script}")
        return False
    
    spec = importlib.util.spec_from_file_location('sisso_predict', predict_script)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    
    return module.run_prediction(config_path)


def main():
    """主函数"""
    parser = argparse.ArgumentParser(
        description='ASAP - Active Symbolic Accelerated Platform',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
示例:
  asap -r              运行工作流（主动学习）
  asap -c              检查环境
  asap -i              显示信息
  asap -p              SISSO 模型预测
  asap -r config/INPUT 使用指定配置文件运行
        '''
    )
    
    # 添加参数
    parser.add_argument('-r', '--run', action='store', nargs='?', const=None, metavar='CONFIG',
                        help='运行工作流（可选：指定配置文件路径）')
    parser.add_argument('-p', '--predict', action='store', nargs='?', const=None, metavar='CONFIG',
                        help='SISSO 模型预测（可选：指定配置文件路径）')
    parser.add_argument('-c', '--check', action='store_true',
                        help='检查环境和依赖')
    parser.add_argument('-i', '--info', action='store_true',
                        help='显示软件信息')
    parser.add_argument('-v', '--version', action='store_true',
                        help='显示版本号')
    
    args = parser.parse_args()
    
    # 无参数时显示帮助
    if len(sys.argv) == 1:
        parser.print_help()
        sys.exit(0)
    
    # 处理参数
    if args.info:
        print_info()
        sys.exit(0)
    
    if args.version:
        print("ASAP v1.0.0")
        sys.exit(0)
    
    if args.check:
        success = check_environment()
        sys.exit(0 if success else 1)
    
    if args.predict is not None:
        # -p 参数（预测功能）
        config_path = args.predict if args.predict else None
        success = run_prediction_cli(config_path)
        sys.exit(0 if success else 1)
    
    if args.run is not None:
        # -r 参数（带或不带配置文件路径）
        config_path = args.run if args.run else None
        success = run_workflow(config_path)
        sys.exit(0 if success else 1)
    
    # 未知参数
    parser.print_help()
    sys.exit(1)


if __name__ == '__main__':
    main()
